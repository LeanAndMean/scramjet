{
	"$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useNodejsImportProtocol": "off",
				"useConst": "error"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noEmptyInterface": "off",
				"noControlCharactersInRegex": "off"
			}
		}
	},
	"files": {
		"includes": [
			"packages/*/src/**/*.ts",
			"packages/*/tests/**/*.ts",
			"packages/*/test/**/*.ts",
			"packages/coding-agent/examples/**/*.ts",
			"!**/node_modules/**/*",
			"!**/dist/**/*",
			"!**/models.generated.ts"
		]
	}
}
