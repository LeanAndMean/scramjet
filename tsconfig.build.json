{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"outDir": "dist",
		"allowImportingTsExtensions": false,
		"rewriteRelativeImportExtensions": true,
		"declaration": true
	},
	"include": [
		"index.ts",
		"types.ts",
		"auto-continue.ts",
		"base-directives.ts",
		"clear-alias.ts",
		"command-status.ts",
		"delegate.ts",
		"history.ts",
		"next-step.ts",
		"pr-indicator.ts",
		"scramjet-command.ts",
		"subagent-output-advisor.ts",
		"tool-scope-advisory.ts",
		"commands/**/*.ts",
		"diagram/**/*.ts"
	],
	"exclude": [
		"tests/**",
		"node_modules",
		"dist",
		"scripts",
		"mach12"
	]
}
