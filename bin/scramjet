#!/usr/bin/env bash
set -euo pipefail

# Thin launcher that execs the `pi` coding-agent harness. Scramjet itself is a
# Pi extension; this shim only exists so users who installed "scramjet" can
# launch with a matching command name. All arguments and env are forwarded.

if ! command -v pi >/dev/null 2>&1; then
	echo "Error: 'pi' is not on PATH." >&2
	echo "Install Pi first: https://github.com/earendil-works/pi-mono" >&2
	exit 127
fi

exec pi "$@"
